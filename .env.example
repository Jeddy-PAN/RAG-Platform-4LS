# App
APP_NAME=Local Enterprise RAG Platform
ENVIRONMENT=local
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000
CORS_ALLOW_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000","http://localhost:3001","http://127.0.0.1:3001"]
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Database
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
POSTGRES_HOST_PORT=5433
DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/rag
TEST_DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5433/rag

# Redis / RQ
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=default

# Upload storage
UPLOAD_STORAGE_DIR=data/uploads
MAX_UPLOAD_SIZE_BYTES=52428800

# OpenAI-compatible chat provider
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=example-chat-model

# Local embedding provider
# Docker Compose reaches host Ollama through host.docker.internal.
# If running the backend directly on macOS, use http://localhost:11434.
EMBEDDING_PROVIDER=ollama
EMBEDDING_BASE_URL=http://host.docker.internal:11434
EMBEDDING_API_KEY=
EMBEDDING_MODEL=bge-m3
EMBEDDING_DIMENSIONS=1024
