# App
APP_NAME=Local Enterprise RAG Platform
ENVIRONMENT=local
API_HOST=0.0.0.0
API_PORT=8000
FRONTEND_PORT=3000

# Database
POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
DATABASE_URL=postgresql+psycopg://rag:rag@postgres:5432/rag

# Redis / RQ
REDIS_URL=redis://redis:6379/0
RQ_QUEUE_NAME=default

# OpenAI-compatible chat provider
LLM_PROVIDER=openai_compatible
LLM_BASE_URL=https://api.example.com/v1
LLM_API_KEY=replace-with-your-api-key
LLM_MODEL=example-chat-model

# OpenAI-compatible embedding provider
EMBEDDING_PROVIDER=openai_compatible
EMBEDDING_BASE_URL=https://api.example.com/v1
EMBEDDING_API_KEY=replace-with-your-api-key
EMBEDDING_MODEL=example-embedding-model
EMBEDDING_DIMENSIONS=1024
